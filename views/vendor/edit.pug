extends ../layout

block content

    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Edit Employee

        a.btn.btn-secondary(href="/vendors")
            | Back

    .card
        .card-body

            form(
                action=`/vendors/${vendor.vendor_id}`
                method="POST"
            )

                .row

                    .col-md-6.mb-3
                        label.form-label Vendor Name

                        input.form-control(
                            type="text"
                            name="vendor_name"
                            value=vendor.vendor_name
                            required
                        )
                    .col-md-6.mb-3
                        label.form-label Contact Person

                        input.form-control(
                            type="text"
                            name="contact_person"
                            value=vendor.contact_person
                            required
                        )
                    .col-md-6.mb-3
                        label.form-label Email

                        input.form-control(
                            type="email"
                            name="email"
                            value=vendor.email
                            required
                        )
                    .col-md-6.mb-3
                        label.form-label Mobile

                        input.form-control(
                            type="text"
                            name="mobile"
                            value=vendor.mobile
                            required
                        )
                    .col-md-6.mb-3
                        label.form-label Address

                        input.form-control(
                            type="text"
                            name="address"
                            value=vendor.address
                            required
                        )   
                    
                button.btn.btn-primary(type="submit")
                    | Update Vendor