extends ../layout

block content

    .d-flex.justify-content-between.align-items-center.mb-4

        h2 Stock View

        a.btn.btn-secondary(href="/assets")
            | Back

    
    .card-body

        h4.mb-3 Branch-wise Stock Summary

        .table-responsive

            table.table.table-bordered.table-striped

                thead.table-dark

                    tr
                        th Branch
                        th Available Assets
                        th Stock Value

                tbody

                    each item in summary

                        tr
                            td= item.branch_name

                            td= item.total_assets

                            td
                                | ₹#{item.total_value.toFixed(2)}

                tfoot.table-secondary

                    tr
                        th Total

                        th= totalAssets

                        th
                            | ₹#{totalValue.toFixed(2)}
                            
    .card
    .card-body

        h4.mb-3 Available Asset Details

        // Branch Filter
        .row.mb-3
            .col-md-4

                label.form-label Filter by Branch

                select#branchFilter.form-select

                    option(value="") All Branches

                    each item in summary
                        option(value=item.branch_name)
                            = item.branch_name


        // Asset Table
        .table-responsive

            table#stockTable.table.table-bordered.table-striped.data-table

                thead.table-dark

                    tr
                        th Asset Code
                        th Asset Name
                        th Serial Number
                        th Category
                        th Vendor
                        th Branch
                        th Purchase Price

                tbody

                    each asset in assets

                        tr
                            td= asset.asset_code

                            td= asset.asset_name

                            td= asset.serial_number || '-'

                            td= asset.category ? asset.category.category_name : '-'

                            td= asset.vendor ? asset.vendor.vendor_name : '-'

                            td= asset.branch ? asset.branch.branch_name : '-'

                            td
                                | ₹#{parseFloat(asset.purchase_price || 0).toFixed(2)}                 