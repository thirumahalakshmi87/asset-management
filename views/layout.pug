doctype html

html

    head

        title= title

        link(
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        )

        link(
            rel="stylesheet"
            href="https://cdn.datatables.net/2.3.7/css/dataTables.bootstrap5.min.css"
        )

    body

        include partials/header

        .container-fluid

            .row

                include partials/sidebar

                main.col-md-10.mt-4

                    block content

        include partials/footer

        script(src="https://code.jquery.com/jquery-3.7.1.min.js")

        script(src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js")

        script(src="https://cdn.datatables.net/2.3.7/js/dataTables.bootstrap5.min.js")

        script.
            $(document).ready(function () {

                // Initialize all normal DataTables
                $('.data-table').each(function () {

                    const table = $(this).DataTable({
                        pageLength: 10,
                        lengthMenu: [5, 10, 25, 50],
                        searching: true,
                        ordering: true
                    });

                });


                // Stock View Branch Filter
                $('#branchFilter').on('change', function () {

                    const branchName = $(this).val();

                    const stockTable =
                        $('#stockTable').DataTable();

                    stockTable
                        .column(5)
                        .search(branchName)
                        .draw();

                });

            });