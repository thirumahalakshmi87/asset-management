extends ../layout

block content

    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Edit Employee

        a.btn.btn-secondary(href="/departments")
            | Back

    .card
        .card-body

            form(
                action=`/departments/${department.department_id}`
                method="POST"
            )

                .row

                    .col-md-6.mb-3
                        label.form-label Department Code

                        input.form-control(
                            type="text"
                            value=department.department_code
                            readonly
                        )

                    .col-md-6.mb-3
                        label.form-label Department Name

                        input.form-control(
                            type="text"
                            name="department_name"
                            value=department.department_name
                            required
                        )

                    .col-md-6.mb-3
                        label.form-label Description

                        input.form-control(
                            type="text"
                            name="description"
                            value=department.description
                        )                                                                                     

                    .col-md-6.mb-3
                        label.form-label Status

                        select.form-select(name="is_active")

                            option(
                                value="true"
                                selected=department.is_active
                            )
                                | Active

                            option(
                                value="false"
                                selected=!department.is_active
                            )
                                | Inactive

                button.btn.btn-primary(type="submit")
                    | Update Department