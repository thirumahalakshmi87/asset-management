extends ../layout

block content

    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Department Details

        a.btn.btn-secondary(href="/departments")
            | Back

    .card
        .card-body

            table.table.table-bordered

                tr
                    th Department Code
                    td= department.department_code

                tr
                    th Department Name
                    td= department.department_name

                tr
                    th Description
                    td= department.description || '-'
                
                tr
                    th Status
                    td
                        if department.is_active
                            span.badge.bg-success Active
                        else
                            span.badge.bg-danger Inactive