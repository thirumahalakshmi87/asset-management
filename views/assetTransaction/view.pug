extends ../layout

block content

    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Asset Transactions

        a.btn.btn-primary(href="/assets/issue")
            | Issue Asset


    .card
        .card-body

            .table-responsive

                table.table.table-bordered.table-striped.data-table

                    thead.table-dark

                        tr
                            th Asset Code
                            th Asset Name
                            th Employee
                            th Issue Date
                            th Expected Return
                            th Return Date
                            th Return Reason
                            th Status


                    tbody

                        each transaction in transactions

                            tr

                                td= transaction.asset_code

                                td= transaction.asset_name

                                td= transaction.employee_name

                                td= transaction.issue_date

                                td= transaction.expected_return_date || '-'

                                td= transaction.return_date || '-'

                                td= transaction.reason_name || '-'

                                td

                                    if transaction.transaction_status === 'ISSUED'

                                        span.badge.bg-warning.text-dark
                                            | Issued

                                    else if transaction.transaction_status === 'RETURNED'

                                        span.badge.bg-success
                                            | Returned