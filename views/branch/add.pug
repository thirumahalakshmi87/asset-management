extends ../layout

block content

    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Add Employee

        a.btn.btn-secondary(href="/branches")
            | Back

    .card
        .card-body

            form(action="/branches" method="POST")

                .row

                    .col-md-6.mb-3
                        label.form-label Branch Code

                        input.form-control(
                            type="text"
                            name="branch_code"
                            required
                        )

                    .col-md-6.mb-3
                        label.form-label Branch Name

                        input.form-control(
                            type="text"
                            name="branch_name"
                            required
                        )

                    .col-md-6.mb-3
                        label.form-label Address

                        input.form-control(
                            type="text"
                            name="address"
                        )
                    
                    .col-md-6.mb-3              
                        label.form-label City

                        input.form-control(
                            type="text"
                            name="city"
                        )
                        
                    .col-md-6.mb-3
                        label.form-label State

                        input.form-control(
                            type="text"
                            name="state"
                        )
                        
                    .col-md-6.mb-3
                        label.form-label Country

                        input.form-control(
                            type="text"
                            name="country"
                        )                                          
                        
                    .col-md-6.mb-3
                        label.form-label Status

                        select.form-select(name="is_active")
                            option(value="true") Active
                            option(value="false") Inactive

                button.btn.btn-primary(type="submit")
                    | Save Branch